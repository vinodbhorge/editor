{
  "compileOnSave": false,
  "compilerOptions": {
    "baseUrl": "./",
    "downlevelIteration": true,
    "outDir": "./dist/out-tsc",
    "sourceMap": true,
    "declaration": false,
    "module": "ES2022",
    "moduleResolution": "bundler",
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "resolveJsonModule": true,
    "typeRoots": [
      "node_modules/@types"
    ],
    "lib": [
      "ES2022",
      "dom"
    ],
    "paths": {
      "questionset-editor-library": [
        "projects/questionset-editor-library/src/public-api.ts"
      ],
      "questionset-editor-library/*": [
        "projects/questionset-editor-library/src/*"
      ]
    },
    "useDefineForClassFields": false,
    "strict": false,
    "skipLibCheck": true
  },
  "angularCompilerOptions": {
    "strictTemplates": false,
    "strictInjectionParameters": false
  }
}