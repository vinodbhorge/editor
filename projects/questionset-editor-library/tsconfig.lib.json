{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "../../out-tsc/lib",
    "declarationMap": true,
    "module": "ES2022",
    "moduleResolution": "node",
    "declaration": true,
    "sourceMap": true,
    "inlineSources": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "types": [],
    "lib": [
      "dom",
      "ES2022"
    ],
    "strict": false,
    "skipLibCheck": true
  },
  "angularCompilerOptions": {
    "compilationMode": "partial",
    "strictMetadataEmit": false,
    "enableResourceInlining": true,
    "generateStandaloneInJit": false
  },
  "exclude": [
    "src/test.ts",
    "**/*.spec.ts"
  ]
}
